<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.gestionaudit.controllers.ClientMainController"
      spacing="20" styleClass="main-container" stylesheets="@../styles/modern.css">
    
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Mes Réclamations" styleClass="header-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvelle Réclamation" onAction="#handleAddReclamation" styleClass="btn, btn-primary"/>
        <Button text="Rafraîchir" onAction="#refreshList" styleClass="btn"/>
    </HBox>

    <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-clean">
        <VBox fx:id="reclamationContainer" spacing="15">
            <!-- Reclamation cards will be added here dynamically -->
        </VBox>
    </ScrollPane>

</VBox>
